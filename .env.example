# Database
DATABASE_URL=postgresql+asyncpg://user:pass@ep-xxx.us-east-2.aws.neon.tech/ci-guardian?sslmode=require

# GitHub App credentials (from GitHub Developer Settings → GitHub Apps)
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_WEBHOOK_SECRET=your_webhook_secret
GITHUB_CLIENT_ID=Ov23li...
GITHUB_CLIENT_SECRET=xyz...
GITHUB_APP_NAME=ci-guardian

# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=cohere/north-mini-code:free

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# Auth
JWT_SECRET=generate-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# App
APP_NAME=CI Guardian
APP_URL=https://ci-guardian.onrender.com
FRONTEND_URL=https://ci-guardian.vercel.app
ENVIRONMENT=production
